#[test(test_rv32mi_p_breakpoint)]
module test_rv32mi_p_breakpoint {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen ( clk );

    var test_succeed: bit;
    inst top: Top #( HEX_FILE: "src/tests/isa/rv32mi-p-breakpoint.hex" ) ( clk, rst, test_succeed );

    initial {
        rst.assert();
        clk.next  (10000);
        $assert   (test_succeed == 1);
        $finish   ();
    }
}

