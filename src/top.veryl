module Top #(
    param HEX_FILE: string = "src/tests/test_sw.hex",
) (
    clk: input clock,
    rst: input reset,
) {
    inst ibus: InstMembus;
    inst dbus: DataMembus;

    inst core: Core (
        clk       ,
        rst       ,
        ibus: ibus,
        dbus: dbus,
    );

    inst mem: Memory #(
        HEX_FILE: HEX_FILE,
    ) (
        clk       ,
        rst       ,
        ibus: ibus,
        dbus: dbus,
    );
}
