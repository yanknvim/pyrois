interface InstMembus {
    var addr: logic<32>;
    var rdata: logic<32>;

    modport master {
        addr: output,
        rdata: input,
    }

    modport slave {
        ..converse(master)
    }
}

interface DataMembus {
    var addr: logic<32>;
    var rdata: logic<32>;

    modport master {
        addr: output,
        rdata: input,
    }

    modport slave {
        ..converse(master)
    }
}
