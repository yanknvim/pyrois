#[test(test_ecall)]
module test_ecall {
    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen ( clk );

    inst top: Top #( HEX_FILE: "src/tests/test_ecall.hex" ) ( clk, rst );

    initial {
        rst.assert();
        clk.next  (2);

        // Wait enough cycles:
        // cycle 0: fetch addr 0 (addi)
        // cycle 1: execute addi, fetch addr 4 (csrrw)
        // cycle 2: execute csrrw, fetch addr 8 (ecall)
        // cycle 3: execute ecall (trap), jump to mtvec (addr 16)
        // cycle 4: fetch addr 16 (handler nop)
        clk.next(5);

        $finish();
    }
}
